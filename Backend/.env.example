# Server Configuration
PORT=8000
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Database
DB_URI=mongodb://localhost:27017/ai_negotiation_agent
# For production MongoDB Atlas:
# DB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-negotiation-agent

# JWT
JWT_SECRET=your_secure_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# AI Services
MISTRAL_API_KEY=your_mistral_api_key
FAKESTORE_API_URL=https://fakestoreapi.com

# Production Configuration Example:
# NODE_ENV=production
# PORT=8000
# ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-backend-domain.com
# DB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-negotiation-agent


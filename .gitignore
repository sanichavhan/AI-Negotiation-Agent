# Root .gitignore

# Environment Variables (CRITICAL - DO NOT COMMIT)
.env
.env.local
.env.*.local
.env.production.local

# Dependencies
node_modules/
package-lock.json
yarn.lock

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build & Dist
dist/
build/

# Documentation (sensitive/internal files)
SETUP_GUIDE.md
CODE_REUSABILITY_GUIDE.md
DEBUGGING_SUMMARY.md
API_TESTING_GUIDE.md
*.pdf
*.doc
*.docx
*.md

# Cache & Temp
.cache/
.vite/
.vite-cache/
*.tmp

# Testing
coverage/
.nyc_output/

# Node version managers
.nvm
.nvmrc

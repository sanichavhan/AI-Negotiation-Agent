# MongoDB Database URL
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-negotiator-game

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters
JWT_EXPIRE=7d

# Mistral AI API Key
MISTRAL_API_KEY=your_mistral_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=production

# Client URL (for CORS)
CLIENT_URL=https://your-frontend-domain.com

# Optional: Additional Configuration
LOG_LEVEL=info
DATABASE_NAME=ai-negotiator-game
